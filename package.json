{
  "name": "todo-workspace",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "npm --prefix client run dev",
    "dev:client": "npm --prefix client run dev",
    "dev:server": "npm --prefix server run dev",
    "dev:fullstack": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "build": "npm --prefix client run build",
    "lint": "npm --prefix client run lint"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
